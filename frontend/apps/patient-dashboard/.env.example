# Copy to `.env.local` for local dev (Vite loads .env.local). Do not commit secrets.
# Values below match outputs from `infrastructure/` after Terraform apply.

VITE_API_URL=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/prod
VITE_USE_MOCK=false

# Patient portal must use the Cognito *patient* app client (not the staff client).
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-south-1
